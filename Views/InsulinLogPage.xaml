<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="DiabetesHelper.Views.InsulinLogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DiabetesHelper.ViewModels"
    xmlns:models="clr-namespace:DiabetesHelper.Models"
    x:DataType="vm:InsulinLogViewModel"
    Title="Insulin">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="ℹ" Clicked="OnAboutToolbarItemClicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Entry Placeholder="Units" Keyboard="Numeric" Text="{Binding NewUnits}" />
            <Picker Title="Type" ItemsSource="{Binding InsulinTypes}" SelectedItem="{Binding NewType}" />
            <Entry Placeholder="Notes (optional)" Text="{Binding NewNotes}" />
            <Button Text="Add Dose" Command="{Binding SaveCommand}" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Doses}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:InsulinDose">
                    <Grid Padding="0,8" ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Notes}" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                            <Label Text="{Binding Units, StringFormat='{0} u'}" FontAttributes="Bold" />
                            <Label Text="{Binding Type}" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding TimestampUtc, StringFormat='{0:g}'}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
