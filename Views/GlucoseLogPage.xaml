<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="DiabetesHelper.Views.GlucoseLogPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DiabetesHelper.ViewModels"
    xmlns:models="clr-namespace:DiabetesHelper.Models"
    x:DataType="vm:GlucoseLogViewModel"
    Title="Blood Sugar">

    <Grid RowDefinitions="Auto,*" Padding="16" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="8">
            <Entry Placeholder="Glucose (mg/dL)" Keyboard="Numeric" Text="{Binding NewValueMgDl}" />
            <Entry Placeholder="Notes (optional)" Text="{Binding NewNotes}" />
            <Button Text="Add Reading" Command="{Binding SaveCommand}" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Readings}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:GlucoseReading">
                    <Grid Padding="0,8" ColumnDefinitions="*,Auto">
                        <Label Text="{Binding Notes}" VerticalOptions="Center" LineBreakMode="TailTruncation" />
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                            <Label Text="{Binding ValueMgDl, StringFormat='{0} mg/dL'}" FontAttributes="Bold" />
                            <Label Text="{Binding TimestampUtc, StringFormat='{0:g}'}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
