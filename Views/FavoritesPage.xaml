<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="DiabetesHelper.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DiabetesHelper.ViewModels"
    xmlns:models="clr-namespace:DiabetesHelper.Models"
    x:DataType="vm:FavoritesViewModel"
    Title="Favorites">

    <CollectionView Margin="16" ItemsSource="{Binding Favorites}">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:FavoriteFood">
                <SwipeView>
                    <SwipeView.RightItems>
                        <SwipeItems>
                            <SwipeItem Text="Delete" BackgroundColor="Red" Invoked="OnDeleteSwipeItemInvoked" />
                        </SwipeItems>
                    </SwipeView.RightItems>
                    <Grid Padding="0,8" ColumnDefinitions="*,Auto">
                        <VerticalStackLayout>
                            <Label Text="{Binding Name}" FontAttributes="Bold" />
                            <Label Text="{Binding UseCount, StringFormat='Used {0} times'}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                            <Label Text="{Binding CarbsGrams, StringFormat='{0} g'}" FontAttributes="Bold" />
                            <Label Text="{Binding GlycemicIndex, StringFormat='GI {0}'}" FontSize="12" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Grid>
                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
