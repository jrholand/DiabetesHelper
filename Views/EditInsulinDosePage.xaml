<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="DiabetesHelper.Views.EditInsulinDosePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:DiabetesHelper.ViewModels"
    x:DataType="vm:EditInsulinDoseViewModel"
    Title="Edit Dose">

    <VerticalStackLayout Padding="16" Spacing="12">
        <Label Text="{Binding SummaryText}" FontAttributes="Bold" />
        <Label Text="{Binding CreatedAtUtc, StringFormat='Created: {0:g}'}" FontSize="12" TextColor="Gray" />

        <Label Text="Effective date/time" Margin="0,12,0,0" />
        <DatePicker Date="{Binding EffectiveDate}" />
        <TimePicker Time="{Binding EffectiveTime}" />

        <HorizontalStackLayout Spacing="8" Margin="0,16,0,0">
            <Button Text="Save" Command="{Binding SaveCommand}" />
            <Button Text="Cancel" Command="{Binding CancelCommand}" />
        </HorizontalStackLayout>
    </VerticalStackLayout>

</ContentPage>
