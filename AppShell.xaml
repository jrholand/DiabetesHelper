<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DiabetesHelper.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:DiabetesHelper.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="DiabetesHelper">

    <TabBar>
        <ShellContent
            Title="Blood Sugar"
            ContentTemplate="{DataTemplate views:GlucoseLogPage}"
            Route="GlucoseLogPage" />

        <ShellContent
            Title="Insulin"
            ContentTemplate="{DataTemplate views:InsulinLogPage}"
            Route="InsulinLogPage" />

        <Tab Title="Carbs">
            <ShellContent
                Title="Log"
                ContentTemplate="{DataTemplate views:MealLogPage}"
                Route="MealLogPage" />

            <ShellContent
                Title="Photo"
                ContentTemplate="{DataTemplate views:MealPhotoPage}"
                Route="MealPhotoPage" />

            <ShellContent
                Title="Favorites"
                ContentTemplate="{DataTemplate views:FavoritesPage}"
                Route="FavoritesPage" />
        </Tab>
    </TabBar>

</Shell>
